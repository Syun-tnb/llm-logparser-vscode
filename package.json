{
  "name": "llm-logparser-analyzer",
  "displayName": "LLM LogParser Analysis Instrument",
  "description": "Hardcore utility wrapper and Liquid dashboard for llm-logparser",
  "version": "1.0.0",
  "publisher": "llm-logparser",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:llmLogparser.openDashboard",
    "onCommand:llmLogparser.openFromExplorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "llmLogparser.openDashboard",
        "category": "LLM LogParser",
        "title": "Open LogParser"
      },
      {
        "command": "llmLogparser.openFromExplorer",
        "category": "LLM LogParser",
        "title": "Open in LLM LogParser"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "llmLogparser.openFromExplorer",
          "when": "resourceExtname == .json || resourceExtname == .jsonl",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "llmLogparser.openDashboard"
        }
      ]
    },
    "configuration": {
      "title": "LLM LogParser",
      "properties": {
        "llmLogparser.pythonPath": {
          "type": "string",
          "default": "python3",
          "scope": "resource",
          "markdownDescription": "Python executable used to run the LogParser CLI when `llmLogparser.cliCommand` is not set."
        },
        "llmLogparser.cliCommand": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Optional full command used to launch LogParser instead of the default `python -m llm_logparser.cli` entry point."
        },
        "llmLogparser.viewer.language": {
          "type": "string",
          "default": "auto",
          "scope": "resource",
          "enum": [
            "auto",
            "en",
            "ja"
          ],
          "enumDescriptions": [
            "Follow the current VS Code display language and fall back to English when Japanese is not active.",
            "Force the LogParser panel UI to English.",
            "Force the LogParser panel UI to Japanese."
          ],
          "markdownDescription": "Language used by the LogParser panel viewer UI."
        }
      }
    }
  },
  "keywords": [
    "llm",
    "logparser",
    "logs",
    "webview"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "copy:assets": "node ./scripts/copy-webview-assets.mjs",
    "compile": "rm -rf dist && tsc -p ./ && npm run copy:assets",
    "watch": "npm run copy:assets && tsc -watch -p ./",
    "package": "rm -rf dist && esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node && npm run copy:assets",
    "test": "npm run compile && node ./dist/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.19.11",
    "mocha": "^10.8.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "marked": "^17.0.5"
  }
}
